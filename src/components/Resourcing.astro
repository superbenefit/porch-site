---
// Resourcing Section — Funding model (brief, muted presentation)
// Design: Smaller, less prominent than other sections
---

<section id="resourcing" class="resourcing">
  <div class="container">
    <h2 class="heading">How It's Funded</h2>
    
    <p class="description">
      Shared cost model: participant co-funding (CAD $30–50K target), web3 sponsorship 
      (USD $25–50K), and in-kind contributor labor from Green Pill Network, Bread 
      Cooperative, OpenCivics Labs, and Gaia AI.
    </p>
    
    <div class="benefits">
      <p class="benefits-intro">Co-funders receive:</p>
      <ul class="benefits-list">
        <li>Curriculum input priority</li>
        <li>Managed IronClaw AI assistant instance</li>
        <li>Additional one-on-one support</li>
      </ul>
    </div>
  </div>
</section>

<style>
  .resourcing {
    /* Muted, lighter background — less prominent */
    background-color: var(--color-cream-light);
    padding-block: var(--space-xl);
  }

  .container {
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-lg);
  }

  .heading {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-charcoal);
    margin-bottom: var(--space-md);
  }

  .description {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    opacity: 0.85;
    line-height: 1.5;
    max-width: 65ch;
    margin-bottom: var(--space-lg);
  }

  .benefits {
    padding: var(--space-md) var(--space-lg);
    background-color: rgba(237, 221, 200, 0.6); /* Subtle cream overlay */
    border-radius: 8px;
    border-left: 3px solid var(--color-orange);
  }

  .benefits-intro {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-charcoal);
    margin-bottom: var(--space-sm);
  }

  .benefits-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .benefits-list li {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    opacity: 0.85;
    padding-block: var(--space-xs);
    position: relative;
    padding-left: var(--space-md);
  }

  .benefits-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-orange);
    font-weight: 600;
  }

  /* Mobile adjustments */
  @media (max-width: 768px) {
    .resourcing {
      padding-block: var(--space-lg);
    }

    .benefits {
      padding: var(--space-md);
    }
  }
</style>
