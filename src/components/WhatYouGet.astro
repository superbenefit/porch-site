---
/**
 * WhatYouGet Component
 *
 * Displays the three session types in a scannable card grid.
 * - Introductory Sessions
 * - Skills Sessions
 * - Deep-Dives
 *
 * Design: Card grid with icons, scannable on mobile.
 */
---

<section id="what-you-get" class="what-you-get">
  <div class="container">
    <h2 class="section-heading">What Your Members Will Learn</h2>

    <div class="cards-grid">
      <!-- Introductory Sessions -->
      <article class="card session-card">
        <div class="card-header">
          <div class="icon-wrapper">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="icon"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 16v-4"></path>
              <path d="M12 8h.01"></path>
            </svg>
          </div>
          <h3 class="card-title">Introductory Sessions</h3>
        </div>
        <ul class="card-list">
          <li class="card-item">
            <span class="bullet"></span>
            <span class="item-text">
              <strong>What AI actually is</strong> — algorithms, data ownership, evaluating tools
            </span>
          </li>
          <li class="card-item">
            <span class="bullet"></span>
            <span class="item-text">
              <strong>Community perspectives</strong> — facilitated sharing of experiences
            </span>
          </li>
          <li class="card-item">
            <span class="bullet"></span>
            <span class="item-text">
              <strong>What&apos;s already happening</strong> — survey of social AI work across Canada
            </span>
          </li>
        </ul>
      </article>

      <!-- Skills Sessions -->
      <article class="card session-card">
        <div class="card-header">
          <div class="icon-wrapper">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="icon"
            >
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
            </svg>
          </div>
          <h3 class="card-title">Skills Sessions</h3>
        </div>
        <ul class="card-list">
          <li class="card-item">
            <span class="bullet"></span>
            <span class="item-text">
              <strong>Filesystems and Markdown</strong> — owning your digital knowledge
            </span>
          </li>
          <li class="card-item">
            <span class="bullet"></span>
            <span class="item-text">
              <strong>Terminals, editors, and AI coding assistants</strong> — hands-on practice
            </span>
          </li>
          <li class="card-item">
            <span class="bullet"></span>
            <span class="item-text">
              <strong>Owning your data and infrastructure</strong> — practical frameworks
            </span>
          </li>
        </ul>
      </article>

      <!-- Deep-Dives -->
      <article class="card session-card">
        <div class="card-header">
          <div class="icon-wrapper">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="icon"
            >
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path>
              <path d="m9 12 2 2 4-4"></path>
            </svg>
          </div>
          <h3 class="card-title">Deep-Dives</h3>
          <span class="subtitle">co-designed with members</span>
        </div>
        <ul class="card-list">
          <li class="card-item">
            <span class="bullet"></span>
            <span class="item-text">Peer exchange with Alliance builders</span>
          </li>
          <li class="card-item">
            <span class="bullet"></span>
            <span class="item-text">Workshops with decentralized AI practitioners</span>
          </li>
          <li class="card-item">
            <span class="bullet"></span>
            <span class="item-text">Knowledge mobilization labs</span>
          </li>
        </ul>
      </article>
    </div>
  </div>
</section>

<style>
  .what-you-get {
    padding-block: var(--space-2xl);
    background-color: var(--color-cream-light);
  }

  .section-heading {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    text-align: center;
    margin-bottom: var(--space-xl);
    color: var(--color-charcoal);
  }

  .cards-grid {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .cards-grid .session-card:last-child {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1024px) {
    .cards-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .cards-grid .session-card:last-child {
      grid-column: auto;
    }
  }

  .session-card {
    background-color: var(--color-cream);
    border-radius: 12px;
    padding: var(--space-lg);
    border: 1px solid rgba(45, 45, 45, 0.1);
    transition: transform var(--transition-medium),
      box-shadow var(--transition-medium);
  }

  .session-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(26, 26, 26, 0.12);
  }

  .card-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background-color: var(--color-orange);
    border-radius: 10px;
    color: var(--color-cream);
  }

  .icon {
    width: 24px;
    height: 24px;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-charcoal);
    margin: 0;
  }

  .subtitle {
    font-size: var(--text-sm);
    color: var(--color-orange);
    font-weight: 500;
    margin-top: -0.25rem;
  }

  .card-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .card-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: var(--text-base);
    line-height: 1.5;
  }

  .bullet {
    display: block;
    width: 6px;
    height: 6px;
    background-color: var(--color-green);
    border-radius: 50%;
    margin-top: 0.5em;
    flex-shrink: 0;
  }

  .item-text {
    color: var(--color-charcoal);
  }

  .item-text strong {
    font-weight: 600;
    color: var(--color-charcoal);
  }

  @media (max-width: 767px) {
    .what-you-get {
      padding-block: var(--space-xl);
    }

    .section-heading {
      font-size: var(--text-xl);
      margin-bottom: var(--space-lg);
    }

    .session-card {
      padding: var(--space-md);
    }

    .icon-wrapper {
      width: 40px;
      height: 40px;
    }

    .icon {
      width: 20px;
      height: 20px;
    }

    .card-title {
      font-size: var(--text-lg);
    }

    .card-item {
      font-size: var(--text-sm);
    }
  }
</style>
